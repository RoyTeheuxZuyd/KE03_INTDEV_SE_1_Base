@page
@model KE03_INTDEV_SE_1_Base.Pages.productenModel

@{
    ViewData["Title"] = "Product page";
}

<div class="producten-page">
    <!-- searchbar, sorting and categories non functional, visual only -->
    <div class="producten-filters">
        <h4>Zoeken & Filters</h4>
        <input type="text"
               class="form-control mb-3"
               placeholder="Zoek een product..." />

        <div class="d-flex flex-wrap gap-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat1">
                <label class="form-check-label" for="cat1">Apparatuur</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat2">
                <label class="form-check-label" for="cat2">Meubels</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat3">
                <label class="form-check-label" for="cat3">Gereedschappen</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat4">
                <label class="form-check-label" for="cat4">Overig</label>
            </div>
        </div>
        <div class="mt-3" style="max-width: 250px;">
            <label for="sorteren" class="form-label">Sorteren</label>
            <select id="sorteren" class="form-select">
                <option selected>Kies sorteeroptie</option>
                <option>Prijs: hoog - laag</option>
                <option>Prijs: laag - hoog</option>
            </select>
        </div>
    </div>

    <hr class="producten-divider" />
    <div class="producten-content">
        <div class="row g-4">
            @foreach (var p in Model.Products)
            {
                var imagePath = $"/Media/{p.ProductImageName}"; <!-- use name of image file to match it to db imagename to load-->

                <div class="col-md-4">
                    <div class="card h-100 shadow">
                        <img src="@imagePath"
                             class="card-img-top"
                             style="height: 250px; object-fit: cover;" />

                        <div class="card-body d-flex flex-column">
                            <h5>@p.Name</h5>
                            @* <p>@p.Description</p> disabled to lessen information overload for customer*@

                            <h4 class="mt-auto">€ @p.Price.ToString("0.00")</h4>
                            <div class="mt-3">
                                <a asp-page="/producteninfo"
                                   asp-route-id="@p.Id"
                                   class="btn btn-info">
                                    Info
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>