@page
@model KE03_INTDEV_SE_1_Base.Pages.productenModel

@{
    ViewData["Title"] = "Product page";
}

<div class="container">
    <div class="row g-4">

        @foreach (var p in Model.Products)
        {
            var imagePath = $"/Media/{p.ProductImageName}";

            <div class="col-md-4">
                <div class="card h-100 shadow">
                    <img src="@imagePath"
                         class="card-img-top"
                         alt="@p.Name"
                         style="height: 250px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            @p.Name
                        </h5>

                        <p class="card-text">
                            @p.Description
                        </p>

                        <h4 class="mt-auto">
                            € @p.Price
                        </h4>

                        <div class="d-flex gap-2 mt-3">
                            <a asp-page="/producteninfo"
                               asp-route-id="@p.Id"
                               class="btn btn-info">
                                Info
                            </a>

                            @* disabled after feedback, but the code still works:
                            <form method="post" asp-page-handler="AddToCart">
                                <input type="hidden" name="id" value="@p.Id" />

                                <button type="submit" class="btn btn-success">
                                    Voeg toe
                                </button>
                            </form> *@
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>