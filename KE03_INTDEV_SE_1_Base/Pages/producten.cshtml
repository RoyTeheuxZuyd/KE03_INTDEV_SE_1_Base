@page
@model KE03_INTDEV_SE_1_Base.Pages.productenModel

@{
    ViewData["Title"] = "Product page";
}

<div class="producten-page">
    <div class="producten-filters">
        <h4>Zoeken & Filters</h4>
        <form method="get" class="mb-3">
            <input type="search"
                   class="form-control"
                   name="search"
                   value="@Request.Query["search"]"
                   placeholder="Zoek een product op naam" />
        </form>

        <h5 class="mt-4">Categorieën</h5>
        <div class="d-flex flex-column gap-2">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat1">
                <label class="form-check-label" for="cat1">Apparatuur</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat2">
                <label class="form-check-label" for="cat2">Meubels</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat3">
                <label class="form-check-label" for="cat3">Gereedschappen</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="cat4">
                <label class="form-check-label" for="cat4">Overig</label>
            </div>
        </div>

        <form method="get" class="mt-5">
            <label for="sort" class="form-label">Sorteren</label>
            <select id="sort"
                    name="sort"
                    class="form-select"
                    onchange="this.form.submit()">
                <option value="" selected="@string.IsNullOrEmpty(Request.Query["sort"])">
                    Standaard sortering
                </option>
                <option value="price_asc" selected="@(Request.Query["sort"] == "price_asc")">
                    Prijs: laag naar hoog
                </option>
                <option value="price_desc" selected="@(Request.Query["sort"] == "price_desc")">
                    Prijs: hoog naar laag
                </option>
                <option value="newest" selected="@(Request.Query["sort"] == "newest")">
                    Nieuw naar oud
                </option>
                <option value="oldest" selected="@(Request.Query["sort"] == "oldest")">
                    Oud naar nieuw
                </option>
            </select>
        </form>
    </div>

    <div class="producten-content">
        <div class="row g-4">
            @foreach (var p in Model.Products)
            {
                var imagePath = $"/Media/{p.ProductImageName}";

                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 shadow">
                        <img src="@imagePath"
                             class="card-img-top"
                             style="height: 250px; object-fit: cover;" />

                        <div class="card-body d-flex flex-column">
                            <h5>@p.Name</h5>
                            <h4 class="mt-auto">€ @p.Price.ToString("0.00")</h4>
                            <div class="mt-3">
                                <a asp-page="/producteninfo" asp-route-id="@p.Id" class="btn btn-info">
                                    Info
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>